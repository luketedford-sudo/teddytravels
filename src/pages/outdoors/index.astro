---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Outdoors | Teddy Travels">
  <section class="page-header">
    <p class="eyebrow">Routes, peaks, trails</p>
    <h1>Outdoors</h1>
    <p>
      Climbing, hiking, backpacking, scrambling, and short expedition reports, organized by region and country.
    </p>
  </section>

  <section class="archive-grid">
    <a class="region-card" href="/outdoors/mountain-west">
      <p class="eyebrow">United States</p>
      <h2>Mountain West</h2>
      <p>
        Idaho, Utah, Wyoming, Montana, Colorado, Nevada, and the high desert /
        alpine places in between.
      </p>
      <span class="region-link">View Mountain West reports →</span>
    </a>
  
    <a class="region-card" href="/outdoors/pacific-northwest">
      <p class="eyebrow">United States</p>
      <h2>Pacific Northwest</h2>
      <p>
        Washington, Oregon, Cascades objectives, fire lookouts, alpine lakes,
        rain, snow, and long drives.
      </p>
      <span class="region-link">View Pacific Northwest reports →</span>
    </a>
  
    <a class="region-card" href="/outdoors/appalachia">
      <p class="eyebrow">United States</p>
      <h2>Appalachia</h2>
      <p>
        Tennessee, North Carolina, Georgia, Virginia, the Smokies, the Blue Ridge,
        and the mountains closer to home.
      </p>
      <span class="region-link">View Appalachia reports →</span>
    </a>
  
    <a class="region-card" href="/outdoors/hawaii">
      <p class="eyebrow">United States</p>
      <h2>Hawaii</h2>
      <p>
        Hawaiian mountains, surf, farm roads, rain, beaches, and whatever island stories
        are worth remembering.
      </p>
      <span class="region-link">View Hawaii reports →</span>
    </a>
  
    <a class="region-card" href="/outdoors/new-zealand">
      <p class="eyebrow">International</p>
      <h2>New Zealand</h2>
      <p>
        Tramps, peaks, huts, coastal tracks, alpine passes, and stories from
        study abroad.
      </p>
      <span class="region-link">View New Zealand reports →</span>
    </a>
  
    <a class="region-card" href="/outdoors/other">
      <p class="eyebrow">Elsewhere</p>
      <h2>Other</h2>
      <p>
        One-offs from locations that do not have their own section yet.
      </p>
      <span class="region-link">View other reports →</span>
    </a>

    <a class="region-card" href="/outdoors/peaks">
      <p class="eyebrow">Peak list</p>
      <h2>Peaks</h2>
      <p>
        A running list of peaks I’ve climbed, sorted by height, with dates,
        regions, and states.
      </p>
      <span class="region-link">View peak list →</span>
    </a>
  </section>
</BaseLayout>
