---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArchiveList from "../../../components/ArchiveList.astro";
import { getCollection } from "astro:content";
import { collectionToArchiveItems } from "../../../lib/content-utils.js";

const books = await getCollection("books", ({ data }) => data.status === "read" && data.draft !== true);
const items = collectionToArchiveItems("books/read", books, "author");
---

<BaseLayout title="Read | Teddy Travels">
  <section class="page-header">
    <p class="eyebrow">Books</p>
    <h1>Read</h1>
    <p>
      Books I have finished and want to remember: novels, travel writing,
      outdoor writing, history, and whatever else stuck with me.
    </p>
  </section>

  <ArchiveList
    heading="Books"
    items={items}
    controlsLabel="Sort books"
    emptyText="No book notes yet. Add one in src/content/books/."
  />
</BaseLayout>
