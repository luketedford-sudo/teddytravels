---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Books | Teddy Travels">
  <section class="page-header">
    <p class="eyebrow">Reading list</p>
    <h1>Books</h1>
    <p>
      Books I have read, books I am reading, and books I want to read.
      Mostly novels, travel writing, outdoor writing, history, and whatever else
      sticks with me.
      <br />
      Currently reading: East of Eden
    </p>
  </section>

  <section class="archive-grid">
    <a class="region-card" href="/books/read">
      <p class="eyebrow">Reflections</p>
      <h2>Read</h2>
    </a>

    <a class="region-card" href="/books/want-to-read">
      <p class="eyebrow">Reading List</p>
      <h2>Want to Read</h2>
    </a>
  </section>
</BaseLayout>
