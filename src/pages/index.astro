---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Teddy Travels">
  <section class="hero">
    <h1>Teddy Travels</h1>
    <p>
      A personal archive of mountains, road trips, surf, work seasons, study abroad,
      and whatever else happens outside.
    </p>
  </section>

  <section>
    <h2>Welcome</h2>
    <p>
      I’m Luke Tedford. This site is my digital scrapbook for trip reports,
      photos, gear notes, objectives, and stories from the road.
    </p>
  </section>

  <section class="card-grid">
    <article class="card">
      <h2>Outdoors</h2>
      <p>Climbing, hiking, backpacking, scrambling, and expedition reports.</p>
      <a href="/outdoors">Explore outdoor reports →</a>
    </article>

    <article class="card">
      <h2>Trips</h2>
      <p>Longer travel stories: road trips, surf trips, work seasons, and international wandering.</p>
      <a href="/trips">Read travel stories →</a>
    </article>

    <article class="card">
      <h2>Photos</h2>
      <p>Favorite shots from trails, peaks, campsites, coastlines, and strange roads.</p>
      <a href="/photos">View gallery →</a>
    </article>

    <article class="card">
      <h2>Objectives</h2>
      <p>Peaks, routes, countries, trails, and ideas I’m chasing.</p>
      <a href="/objectives">See objectives →</a>
    </article>
  </section>
</BaseLayout>