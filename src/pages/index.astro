---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Teddy Travels">
  <section class="hero hero-with-photos">
    <div class="hero-copy">
      <p class="eyebrow">A digital archive by Luke Tedford</p>
      <h1>Teddy Travels</h1>
      <p>
        Mountains, road trips, surf, work seasons, photos, and gear notes.
      </p>
    </div>

    <div class="hero-photos" aria-label="Photos of Luke outdoors">
      <img
        class="hero-photo hero-photo-main"
        src="/images/home/luke-1.jpg"
        alt="Luke outdoors on a trip"
      />
      <img
        class="hero-photo hero-photo-small"
        src="/images/home/luke-2.jpg"
        alt="Luke on another outdoor trip"
      />
      <img
        class="hero-photo hero-photo-small"
        src="/images/home/luke-3.jpg"
        alt="Luke traveling"
      />
    </div>
  </section>

  <section class="intro">
    <h2>What this is</h2>
    <p>
      This website is my digital scrapbook: part trip report collection, part photo
      archive, part gear notebook, and part record of the places I’ve been and
      the objectives I’m working toward.
    </p>
  </section>

  <section class="card-grid">
    <a class="card feature-card" href="/outdoors">
      <p class="eyebrow">Routes, peaks, trails</p>
      <h2>Outdoors</h2>
      <p>
        Climbing, hiking, backpacking, scrambling, and short expedition
        reports, organized by region and country.
      </p>
      <span>Explore reports →</span>
    </a>
  
    <a class="card feature-card" href="/trips">
      <p class="eyebrow">Longer stories</p>
      <h2>Trips</h2>
      <p>
        Longer adventures and travel stories. Surf trips, road trips, and seasonal work.
      </p>
      <br>
      <span>Read travel stories →</span>
    </a>
  
    <a class="card feature-card" href="/photos">
      <p class="eyebrow">Image gallery</p>
      <h2>Photos</h2>
      <p>
        Favorite shots from trails, peaks, campsites, and coastlines.
      </p>
      <br>
      <br>
      <span>View gallery →</span>
    </a>
  
    <a class="card feature-card" href="/objectives">
      <p class="eyebrow">Future missions</p>
      <h2>Objectives</h2>
      <p>
        Peaks, routes, countries, trails, and goals for the future.
      </p>
      <br>
      <br>
      <span>See objectives →</span>
    </a>
  
    <a class="card feature-card" href="/gear">
      <p class="eyebrow">Equipment</p>
      <h2>Gear</h2>
      <p>
        The backpacks, tents, boots, and more that I’ve used on trips,
        and my thoughts on what worked and what didn’t.
      </p>
      <span>Read gear reviews →</span>
    </a>
  
    <a class="card feature-card" href="/books">
      <p class="eyebrow">Reading list</p>
      <h2>Books</h2>
      <p>
        Books I have read, books I am reading, and books I want to read.
      </p>
      <br>
      <br>
      <span>Read book reviews →</span>
    </a>
  </section>

  <section class="quote-block">
    <p>
      “No weapon formed against me shall prosper”
      <br />
      - Isaiah 54:17
    </p>
  </section>
</BaseLayout>