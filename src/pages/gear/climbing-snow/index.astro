---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArchiveList from "../../../components/ArchiveList.astro";
import { getCollection } from "astro:content";
import { collectionToArchiveItems } from "../../../lib/content-utils.js";

const notes = await getCollection("gear", ({ data }) => data.category === "Climbing & Snow" && data.draft !== true);
const items = collectionToArchiveItems("gear", notes, "type");
---

<BaseLayout title="Climbing & Snow Gear | Teddy Travels">
  <section class="page-header">
    <p class="eyebrow">Gear</p>
    <h1>Climbing & Snow</h1>
    <p>Boots, crampons, axes, helmets, ski gear, glacier gear, and the alpine setup I am slowly building toward.</p>
  </section>

  <ArchiveList
    heading="Notes"
    items={items}
    controlsLabel="Sort gear notes"
    emptyText="No gear notes here yet. Add one in src/content/gear/climbing-snow/."
  />
</BaseLayout>
