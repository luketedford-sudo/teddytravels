---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Gear | Teddy Travels">
  <h1>Gear</h1>
  <p>
    Gear I use, gear I regret carrying, gear that broke, and gear I’d buy again.
  </p>

  <div class="card-grid gear-grid">
    <article class="card">
      <h2>Backpacking</h2>
      <p>Packs, tents, sleep systems, filters, stoves, and clothing.</p>
    </article>

    <article class="card">
      <h2>Running</h2>
      <p>Shoes, watches, hydration, layers, and race notes.</p>
    </article>

    <article class="card">
      <h2>Climbing & Snow</h2>
      <p>Helmets, axes, crampons, layers, and safety gear.</p>
    </article>
  </div>
</BaseLayout>