---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArchiveList from "../../../components/ArchiveList.astro";
import { getCollection } from "astro:content";
import { collectionToArchiveItems } from "../../../lib/content-utils.js";

const reports = await getCollection("trips", ({ data }) => data.type === "Road Trips" && data.draft !== true);
const items = collectionToArchiveItems("trips", reports, "place");
---

<BaseLayout title="Road Trips | Teddy Travels">
  <section class="page-header">
    <p class="eyebrow">Trips</p>
    <h1>Road Trips</h1>
    <p>Big drives, weird stops, national forests, diners, campsites, and detours.</p>
  </section>

  <ArchiveList
    heading="Reports"
    items={items}
    controlsLabel="Sort reports"
    emptyText="No reports here yet. Add one in src/content/trips/road-trips/."
  />
</BaseLayout>
